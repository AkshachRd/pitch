{
  "name": "@pitch/ui",
  "version": "0.0.0",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    "./styles.css": "./dist/index.css",
    "./*": "./src/*.tsx"
  },
  "scripts": {
    "build": "tailwindcss -i ./src/styles.css -o ./dist/index.css",
    "check-types": "tsc --noEmit",
    "dev": "tailwindcss -i ./src/styles.css -o ./dist/index.css --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "devDependencies": {
    "@pitch/eslint-config": "workspace:*",
    "@pitch/tailwind-config": "workspace:*",
    "@pitch/typescript-config": "workspace:*",
    "@types/node": "^22.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "^9.24.0",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.16",
    "typescript": "5.8.3",
    "@react-aria/ssr": "^3.9.7",
    "@react-aria/visually-hidden": "^3.8.18",
    "clsx": "^2.1.1",
    "next-themes": "^0.4.4"
  },
  "peerDependencies": {
    "react": "^18"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}